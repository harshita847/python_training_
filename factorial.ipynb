   "source": [
    "def even_fact(n):\n",
    "    ans=1\n",
    "    for i in range(2,n+1,2):\n",
    "        ans*=i\n",
    "    return ans\n",
    "\n",
    "def odd_fact(n):\n",
    "    ans=1\n",
    "    for i in range(1,n+2,2):\n",
    "        ans*=i\n",
    "    return ans\n",
    "\n",
    "n=int(input(\"enter no:\"))\n",
    "if(n%2==0):\n",
    "    print(even_fact(n))\n",
    "else:\n",
    "    print(odd_fact(n))\n"
   ]
  }
